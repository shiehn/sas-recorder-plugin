{
  "name": "@signalsandsorcery/recorder",
  "version": "1.0.0",
  "description": "Loop-aware microphone recording plugin for Signals & Sorcery — each loop creates a muted take",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugin.json": "./plugin.json"
  },
  "files": [
    "dist",
    "plugin.json"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@signalsandsorcery/plugin-sdk": "^2.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@signalsandsorcery/plugin-sdk": "^2.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shiehn/sas-recorder"
  },
  "keywords": [
    "signals-and-sorcery",
    "plugin",
    "audio",
    "recording",
    "music",
    "daw"
  ]
}
